# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database Type: sqlite, postgresql, mysql
DB_TYPE=postgresql

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=olist_warehouse
DB_USER=postgres
DB_PASSWORD=your_password_here

# MySQL Configuration (if using MySQL)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=olist_warehouse
# DB_USER=root
# DB_PASSWORD=your_password_here

# SQLite Configuration (if using SQLite)
# SQLITE_DB_PATH=data/warehouse/olist_warehouse.db

# ============================================================================
# DATA DIRECTORIES
# ============================================================================

DATA_DIR=data/raw/
STAGING_DIR=data/staging/
OUTPUT_DIR=output/
LOGS_DIR=logs/

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/data_pipeline.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================================================
# PIPELINE CONFIGURATION
# ============================================================================

# Execution mode: development, production, testing
RUN_MODE=development

# Dry run mode (if true, won't write to database)
DRY_RUN=false

# Batch size for data loading
BATCH_SIZE=10000

# Number of parallel processes
NUM_WORKERS=4

# ============================================================================
# ORCHESTRATION CONFIGURATION
# ============================================================================

# Dagster Configuration
DAGSTER_PORT=3000
DAGSTER_HOME=./dagster_home

# Scheduler Configuration
SCHEDULER_ENABLED=true
DAILY_RUN_TIME=02:00
WEEKLY_RUN_DAY=0
WEEKLY_RUN_TIME=03:00

# ============================================================================
# DATA QUALITY CONFIGURATION
# ============================================================================

# Enable data quality checks
QUALITY_CHECKS_ENABLED=true

# Fail pipeline on quality check failures
FAIL_ON_QUALITY_ERROR=false

# Data quality thresholds
NULL_VALUES_THRESHOLD=0.01
DUPLICATE_THRESHOLD=0.0
REFERENTIAL_INTEGRITY_THRESHOLD=0.0

# ============================================================================
# NOTIFICATION CONFIGURATION
# ============================================================================

# Email notifications
NOTIFICATION_ENABLED=false
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SENDER_EMAIL=your_email@gmail.com
# SENDER_PASSWORD=your_app_password
# RECIPIENT_EMAILS=recipient@example.com,another@example.com

# Slack notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# SLACK_CHANNEL=#data-pipeline

# ============================================================================
# CLOUD STORAGE (Optional - AWS S3)
# ============================================================================

# AWS Configuration (if using S3 for data storage)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET=olist-data-warehouse
# S3_PREFIX=data/

# ============================================================================
# ANALYSIS CONFIGURATION
# ============================================================================

# Analysis date range (YYYY-MM-DD format)
ANALYSIS_START_DATE=2015-01-01
ANALYSIS_END_DATE=2022-01-01

# Customer segmentation thresholds
VIP_THRESHOLD=5000
HIGH_VALUE_THRESHOLD=1000
MEDIUM_VALUE_THRESHOLD=300

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# API Keys and Secrets (if applicable)
# API_KEY=your_api_key
# SECRET_KEY=your_secret_key

# Enable SSL/TLS for database connections
SSL_ENABLED=false
SSL_CERT_PATH=/path/to/cert.pem

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable specific pipeline stages
ENABLE_INGESTION=true
ENABLE_TRANSFORMATION=true
ENABLE_QUALITY_CHECKS=true
ENABLE_ANALYSIS=true
ENABLE_AGGREGATION=true

# Feature flags for analysis
ENABLE_FORECASTING=false
ENABLE_CLUSTERING=false
ENABLE_ANOMALY_DETECTION=false

# ============================================================================
# DEBUG & DEVELOPMENT
# ============================================================================

# Debug mode
DEBUG=false

# Verbose logging
VERBOSE=false

# Profile execution time
PROFILE_EXECUTION=false

# Limit rows for testing (0 = no limit)
LIMIT_ROWS=0

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Connection pool size
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Query timeout (seconds)
QUERY_TIMEOUT=300

# Chunk size for large data loads
CHUNK_SIZE=50000

# ============================================================================
# BACKUP & RECOVERY
# ============================================================================

# Enable automated backups
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_LOCATION=data/backups/

# Retention policy (days)
BACKUP_RETENTION_DAYS=30
